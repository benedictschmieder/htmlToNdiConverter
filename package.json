{
  "name": "web2ndi",
  "productName": "Web2NDI",
  "version": "2.1.0",
  "description": "Renders a live web page (HTML stream) offscreen and outputs it as an NDI video source for media production and streaming.",
  "main": "src/main.js",
  "author": "Benedict Schmieder",
  "license": "MIT",
  "scripts": {
    "build:native": "node scripts/build-native.js",
    "install": "node scripts/build-native.js",
    "make:icons": "node scripts/make-icons.js",
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "dependencies": {
    "node-addon-api": "^8.8.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "node-gyp": "^13.0.0"
  },
  "build": {
    "appId": "media.htmltondi.converter",
    "productName": "Web2NDI",
    "files": [
      "src/**/*",
      "config.json",
      "build/Release/ndi_sender.node"
    ],
    "extraResources": [
      {
        "from": "config.json",
        "to": "../config.json"
      }
    ],
    "extraFiles": [
      {
        "from": "vendor/ndi/Bin/x64/Processing.NDI.Lib.x64.dll",
        "to": "Processing.NDI.Lib.x64.dll"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "asarUnpack": [
      "build/Release/ndi_sender.node"
    ]
  }
}
